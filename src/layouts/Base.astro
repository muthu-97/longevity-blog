---
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = 'Longevity, in plain words. Written by Muthu, founder of Club EverStrong.' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>
  <main class="wrap">
    <slot />
  </main>
</body>
</html>
